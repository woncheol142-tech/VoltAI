PROJECT_ROOT=./project
KEC_DB_PATH=./.voltai/kec.sqlite
KNOWLEDGE_DB_PATH=./.voltai/knowledge.sqlite
# Explicit provider selection is required; placeholder is for offline development and tests only.
KEC_EMBED_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_TIMEOUT_MS=30000
# Company and Material placeholder providers are deterministic test aids, not pilot-quality retrieval.
COMPANY_EMBED_PROVIDER=placeholder
MATERIAL_EMBED_PROVIDER=placeholder
